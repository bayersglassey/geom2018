
# May be used for spider *or* coin_beast!

collmap "danger_check":
    # This is obviously silly.
    # Instead of a giant collmap, let's calculate distance instead.
    # So, we want a rule cond which checks if any bodies with a given collmsg
    # are within some distance (presumably a valexpr).
    # Although... it's not so clear to me whether "danger_check_b/f"
    # could be made to work that way...
    # But perhaps that's fine; we only need them after "danger_check" has caused
    # us to enter the "hiding" state, and *that* check at least should ideally
    # be cheap.
    ;;                                + - + - + - + - + - + - + - + - + - + - +
    ;;                               /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;                              + - + - + - + - + - + - + - + - + - + - + - +
    ;;                             /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;                            + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;                           /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;                          + - + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;                         /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;                        + - + - + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;                       /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;                      + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;                     /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;                    + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;                   /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;                  + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;                 /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;                + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;               /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;              + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;             /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;            + - + - + - + - + - + - + - + - + - + -(+)- + - + - + - + - + - + - + - + - + - +
    ;;             \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;              + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;               \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;                 \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                  + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;                   \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                    + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;                     \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                      + - + - + - + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;                       \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                        + - + - + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;                         \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                          + - + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;                           \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                            + - + - + - + - + - + - + - + - + - + - + - + - +
    ;;                             \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                              + - + - + - + - + - + - + - + - + - + - + - +
    ;;                               \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                                + - + - + - + - + - + - + - + - + - + - +

collmap "danger_check_b":
    ;;                                +
    ;;                               /*\
    ;;                              + - +
    ;;                             /*\*/*\
    ;;                            + - + - +
    ;;                           /*\*/*\*/*\
    ;;                          + - + - + - +
    ;;                         /*\*/*\*/*\*/*\
    ;;                        + - + - + - + - +
    ;;                       /*\*/*\*/*\*/*\*/*\
    ;;                      + - + - + - + - + - +
    ;;                     /*\*/*\*/*\*/*\*/*\*/*\
    ;;                    + - + - + - + - + - + - +
    ;;                   /*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;                  + - + - + - + - + - + - + - +
    ;;                 /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;                + - + - + - + - + - + - + - + - +
    ;;               /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;              + - + - + - + - + - + - + - + - + - +
    ;;             /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;            + - + - + - + - + - + - + - + - + - + -(+)
    ;;             \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;              + - + - + - + - + - + - + - + - + - +
    ;;               \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                + - + - + - + - + - + - + - + - +
    ;;                 \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                  + - + - + - + - + - + - + - +
    ;;                   \*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                    + - + - + - + - + - + - +
    ;;                     \*/*\*/*\*/*\*/*\*/*\*/
    ;;                      + - + - + - + - + - +
    ;;                       \*/*\*/*\*/*\*/*\*/
    ;;                        + - + - + - + - +
    ;;                         \*/*\*/*\*/*\*/
    ;;                          + - + - + - +
    ;;                           \*/*\*/*\*/
    ;;                            + - + - +
    ;;                             \*/*\*/
    ;;                              + - +
    ;;                               \*/
    ;;                                +

collmap "danger_check_f":
    ;;                                +
    ;;                               /*\
    ;;                              + - +
    ;;                             /*\*/*\
    ;;                            + - + - +
    ;;                           /*\*/*\*/*\
    ;;                          + - + - + - +
    ;;                         /*\*/*\*/*\*/*\
    ;;                        + - + - + - + - +
