    ;;                 /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;                + - + - + - + - + - + - + - + - +
    ;;               /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;              + - + - + - + - + - + - + - + - + - +
    ;;             /*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\
    ;;           (+)- + - + - + - + - + - + - + - + - + - +
    ;;             \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;              + - + - + - + - + - + - + - + - + - +
    ;;               \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                + - + - + - + - + - + - + - + - +
    ;;                 \*/*\*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                  + - + - + - + - + - + - + - +
    ;;                   \*/*\*/*\*/*\*/*\*/*\*/*\*/
    ;;                    + - + - + - + - + - + - +
    ;;                     \*/*\*/*\*/*\*/*\*/*\*/
    ;;                      + - + - + - + - + - +
    ;;                       \*/*\*/*\*/*\*/*\*/
    ;;                        + - + - + - + - +
    ;;                         \*/*\*/*\*/*\*/
    ;;                          + - + - + - +
    ;;                           \*/*\*/*\*/
    ;;                            + - + - +
    ;;                             \*/*\*/
    ;;                              + - +
    ;;                               \*/
