    ;;

shapes:

    "empty":
        prismels:

    "vert":
        prismels:
            : "vert"  (0 0 0 0)  0 f 2

    "edge":
        prismels:
            : "edge"  (0 0 0 0)  0 f 2

    "sq":
        prismels:
            : "sq"  (0 0 0 0)  0 f 2

    "tri":
        prismels:
            : "tri" (0 0 0 0)  0 f 2

    "dia":
        prismels:
            : "dia" (0 0 0 0)  0 f 2

$SET_STR NS spider_
$UNSET_BOOL EYESPIDER
import "data/_spider.fus"

$SET_STR NS eyespider_
$SET_BOOL EYESPIDER
import "data/_spider.fus"
# Loads just enough stuff into a prismelrenderer so that you can
# get a geomfont out of it

import "data/prismels.fus"
import "data/geomfonts.fus"

collmap:
    ;;
