    ;;            * * *     * *  \     /                                                         \* * * *     * *
    ;;        .   .   .   .   .   +   +   .   .   .   .   .   .   .   .   .   .   ?   .   .   .   +   .   .   .   .   .      [g]
    ;;                        * * *\ /                                                           /*\* * * *
    ;;          .   .   .   .   + - +   .   .   .   .   .   .   .   .   .   .   .   .   .   .   +   +   .   .   .   .   .
    ;;                  *   * */                                                                 \*/* * *
    ;;            .   .   .   +   .   .   .   .   .   .   .   .   .   .   .   .   .   .   .   .   +   ?   .   .   .   .          [A]
