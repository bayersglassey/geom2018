    ;;        saved.

text:
    if mapvar("made_it_underneath") then null
    else if mapvar("reached_cage") then $GET_STR SAVEPOINT_C2
    else $GET_STR SAVEPOINT_C
parts:
    "l": location "cage"
collmap:
    ;;
