    ;; .   .   .   .   +   .   .   .   .   ?   .   .   +   .   .   .   +   + - +   .   + - + = @ = + = @ = @ = + - +   .   .   .   .   .   .   [e]
    ;;                /*                                \                 /     \     /     \o      \           \ /          * *\          * *
    ;;   .   .   .   + - +   .   .   .   .   .   .   .   +   .   .   +   +   .   +   +   .   +   .   +   .   .   +   .   .   .   + - +   .   .
