    ;;           *  /            *   *                \     /                 \         /o          /   /                 \*   *   *
    ;; .   .   .   +   .   .   .   .   .   .   .   .   + - +   .   .   .   .   +   + - + = @ = @ = + - +   .   .   .   .   .   .   .   .   .
