parts:
    "A": recording "data/recs/eye.fus"
        vars:
            "key": "coin_f"
    "f": recording "data/recs/coin.fus"
        vars:
            "appear": T
            "key": "coin_e"
            "collected_key": "coin_f"
    "g": recording "data/recs/coin.fus"
        vars:
            "appear": T
            "key": "coin_f"
            "collected_key": "start_solved"
            "num_key": "num_coin_g"
collmap:
    ;;
    ;;          .   .   .   .   .   .   .   .   + - + - + - +   .   .   .   .   .   .   .   .   .   .   .   .   .   .   .
