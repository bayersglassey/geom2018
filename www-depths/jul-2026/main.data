    ;;   *   *    \      *                            \                       \ /             \               \                  *  /
    ;; .   .   .   + - +   .   +   .   .   .   .   .   +   .   .   .   .   +   +   .   .   .   +   .   .   .   + - +   .   .   .   +   .   .
