    ;; .   .   .   + - + - . - .   .   .   .   .   +   +   .   .   .   .   .   +   +   .   +   .   .   .   .   +   .   .   .   .   +   .   .
    ;;         *  /        *\ /*                    \ /                       /   /         \                 /                     \* * *
