    ;;                     =           =     =               =                   =     =         \       \     /     \
    ;;        .   .   .   + - + - + - + = @ = @ = @ = @ = @ = @ = @ = @ = @ = @ = + - +   .   .   +   .   +   +   .   +   .   .
    ;;                   /             \       =               =                 /     \           \     /     \     /
