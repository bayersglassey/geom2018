collmap:
    ;;
    ;; .   .   .   .   .   .   .   .   .
    ;;
    ;;   .   .   .   .   +   .   .   .   .
    ;;                  /
    ;; .   .   .   .   +   .   .   .   .   .
    ;;                /
    ;;   .   .   .   +   .   .   + - +   .   .
    ;;              /           /* */
    ;; .   .   .   + - +   + - + - +   .   .   .
    ;;            /* */   /* */
    ;;   .   + - +   +   + - +   + - +   .   .   .
