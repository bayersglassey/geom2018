    ;;               *   *   *  / \                       \                 /     \                          * * *      /  * * *
    ;; .   .   + - +   .   .   .   .   .   .   .   .   .   +   .   .   + - +   .   + - +   .   .   .   .   .   .   .   +   .   .   .   .   .
    ;;        /     \*                                      \               \       \   \                        * * */
