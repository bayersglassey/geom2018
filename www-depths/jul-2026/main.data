    ;;      . - + - + -(+)- + - + - .
    ;;        */*\*/*\*/*\*/*\*/*\*
    ;;        . - + - + - + - + - .
    ;;          */*\*/*\*/*\*/*\*
    ;;          . - + - + - + - .
    ;;            */*\*/*\*/*\*
    ;;            .   .   .   .

