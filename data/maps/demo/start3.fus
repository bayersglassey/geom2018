    ;;               .   .                                                   ?                  [C]
    ;;                                                                       M
    ;;                 ?                                   + - + - + - + - + - + - + - +          [a^3]
    ;;                                                    /                             \
    ;;   .   .   ?   .   .   ?   .   .   ?       ?       +       + - + - + - + - +       +     [A][A][A][B]
    ;;                                                  /       /                 \     /
    ;;                             @ = @ = @ = + - + - +       +       +       +   + - +   .   .   ?         [b^5]
    ;;                                        /               /         \       \
    ;;                                       +       + - + - +           +       +           .   .
    ;;              %*                        \     /                                                        [0]
    ;;           %(+)- .   .   .   .   .   .   + - +                       +       +           .             [00]
    ;;
    ;;           .   ?                                                       .       .                       [h]
    ;;
    ;;         .                               .                               .       .
    ;;
    ;;       .                                                                   .       .
    ;;  %* */                                                                                  [000]
    ;;  %  +   .                               .                                   .       .   [  0]
