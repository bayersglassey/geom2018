
# Expected variables:
# RGRAPH_NS (str): e.g. "string_"

$SET_INT MAX_AGE 100


state "appear":
    if:
    then: goto delay: "_appear"

state "_appear":
    rgraph: $PREFIX RGRAPH_NS "appear"

    if:
    then: goto: "stay"

state "stay":
    rgraph: $PREFIX RGRAPH_NS "stay"

    nostop if:
    then:
        inc myvar("age")

    if: expr: > myvar("age") $GET_INT MAX_AGE
    then: goto delay: "disappear"

state "disappear":
    rgraph: $PREFIX RGRAPH_NS "disappear"

    if:
    then: remove
