
state "start_jump":
    unsafe

    "fly"
    if:
        expr: myvar("is_flierspider")
        key: wasdown x
        coll: all no
            ;;       \*/*
            ;;        + -
            ;;       /*\*
            ;; ( )
    then:
        goto: "flier_fly"
        move: 2 1
        delay: 2

    "swim"
    if:
        coll: water any yes collmap("stand")
    then:
        goto delay: "swim_jump"

    "default"
    if() then:
        if: expr: > myvar("coin_power") 0
        then: goto delay: "power_jump"
        else: goto delay: "jump"

state "jump":
    # NOTE: the only `goto: "jump"` is in "start_jump", which checks whether
    # we're in water, and does `goto: jump` or `goto: "swim_jump"`
    # accordingly.
    # Therefore, if we're in "jump", then we can safely assume we're not in
    # water without checking.

    unsafe
    rgraph: $PREFIX NS "jump"
    hitbox: collmap("stand")

    "spawn_string"
    nostop if:
    then:
        spawn: "anim/string.fus" "appear" (0 0) 0 f

    # Landing, jumping, crashing
    import "anim/_walker_jumping.state.fus"

state "power_jump":
    # Like "jump", but faster! For when we have coin power.

    unsafe
    rgraph: $PREFIX NS "power_jump"
    hitbox: collmap("stand")

    "spawn_trail"
    nostop if:
    then:
        spawn: "anim/power_trail.fus" "appear" (0 0) 0 f

    # Landing, jumping, crashing
    import "anim/_walker_jumping.state.fus"
